---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import RepoCard from "../components/RepoCard.astro";
import { getRepos } from "../lib/github";

// Last 3 blog posts (excluding drafts), newest first
const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// All public GitHub repos
const repos = await getRepos();

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { day: "numeric", month: "long", year: "numeric" });
---

<Base title="Çağatay Üresin — Portfolio">
  <section class="container hero">
    <h1>Hi, I'm Çağatay 👋</h1>
    <p>
      Backend Developer & SRE/DevOps. I write about Kubernetes, GitOps, and
      AI, and build open-source projects.
    </p>
  </section>

  <section class="container">
    <div class="section-head">
      <h2 class="section-title">Latest Posts</h2>
      <a href="/blog" class="section-link">View all posts →</a>
    </div>
    <div class="card-grid">
      {
        posts.map((p) => (
          <PostCard
            href={`/blog/${p.id}`}
            title={p.data.title}
            description={p.data.description}
            date={fmt(p.data.pubDate)}
            tags={p.data.tags}
          />
        ))
      }
    </div>

    <h2 class="section-title">Projects</h2>
    <div class="card-grid">
      {repos.map((r) => <RepoCard repo={r} />)}
      {
        repos.length === 0 && (
          <p class="card-desc">
            GitHub repos are fetched at build time (shows empty if the API
            rate limit is hit or there's no network access).
          </p>
        )
      }
    </div>
  </section>
</Base>
