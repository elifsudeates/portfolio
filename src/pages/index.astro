---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import RepoCard from "../components/RepoCard.astro";
import { getRepos } from "../lib/github";

// Last 3 blog posts (excluding drafts), newest first
const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Top 6 most-starred public repos
const featuredRepos = (await getRepos())
  .sort((a, b) => b.stargazers_count - a.stargazers_count)
  .slice(0, 6);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { day: "numeric", month: "long", year: "numeric" });
---

<Base title="Çağatay Üresin — Portfolio">
  <section class="container hero">
    <h1>Hi, I'm Çağatay 👋</h1>
    <p>
      AI Integration & Deployment Engineer focused on production LLM-backed
      backend integrations, semantic search, and Kubernetes-based deployment.
      Strong backend foundation in Python, Go, and Java. I write about
      Kubernetes, GitOps, and AI, and build open-source projects.
    </p>
    <a href="/cv" class="section-link">View full CV →</a>
  </section>

  <section class="container">
    <div class="section-head">
      <h2 class="section-title">Latest Posts</h2>
      <a href="/blog" class="section-link">View all posts →</a>
    </div>
    <div class="card-grid">
      {
        posts.map((p) => (
          <PostCard
            href={`/blog/${p.id}`}
            title={p.data.title}
            description={p.data.description}
            date={fmt(p.data.pubDate)}
            tags={p.data.tags}
            cover={p.data.cover}
          />
        ))
      }
    </div>

    <div class="section-head">
      <h2 class="section-title">Featured Projects</h2>
      <a href="/projects" class="section-link">View all projects →</a>
    </div>
    <div class="card-grid repo-grid">
      {featuredRepos.map((r) => <RepoCard repo={r} />)}
      {
        featuredRepos.length === 0 && (
          <p class="card-desc">
            GitHub repos are fetched at build time (shows empty if the API
            rate limit is hit or there's no network access).
          </p>
        )
      }
    </div>
  </section>
</Base>
