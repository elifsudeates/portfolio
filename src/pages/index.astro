---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import RepoCard from "../components/RepoCard.astro";
import { getRepos } from "../lib/github";

// Last 3 blog posts (excluding drafts), newest first
const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Top 6 most-starred public repos
const featuredRepos = (await getRepos())
  .sort((a, b) => b.stargazers_count - a.stargazers_count)
  .slice(0, 6);

const fmt = (d: Date) =>
  d.toLocaleDateString("tr-TR", { day: "numeric", month: "long", year: "numeric" });
---

<Base
  title="Elif Sude Ateş — Portfolio"
  description="Elif Sude Ateş'in portfolyosu ve teknik blogu. Siber güvenlik, makine öğrenmesi, Kubernetes ve açık kaynak projeler üzerine çalışmalar."
  canonicalPath="/"
>
  <section class="container hero">
    <h1>Merhaba, Ben Elif 👋</h1>
    <p>
      Siber Güvenlik, Makine Öğrenmesi, Kubernetes ve AI entegrasyonlarına odaklanan bir geliştiriciyim. Yeni teknolojileri denemeyi, projeler geliştirmeyi ve bunları paylaşmayı seviyorum. Python, Go ve Java dillerinde tecrübem bulunuyor.
    </p>
    <a href="/cv" class="section-link">Tüm özgeçmişimi görüntüle →</a>
  </section>

  <section class="container">
    <div class="section-head">
      <h2 class="section-title">Son Yazılar</h2>
      <a href="/blog" class="section-link">Tüm yazıları görüntüle →</a>
    </div>
    <div class="card-grid">
      {
        posts.map((p) => (
          <PostCard
            href={`/blog/${p.id}`}
            title={p.data.title}
            description={p.data.description}
            date={fmt(p.data.pubDate)}
            tags={p.data.tags}
            cover={p.data.cover}
          />
        ))
      }
    </div>

    <div class="section-head">
      <h2 class="section-title">Öne Çıkan Projeler</h2>
      <a href="/projects" class="section-link">Tüm projeleri görüntüle →</a>
    </div>
    <div class="card-grid repo-grid">
      {featuredRepos.map((r) => <RepoCard repo={r} />)}
      {
        featuredRepos.length === 0 && (
          <p class="card-desc">
            GitHub projeleri derleme sırasında çekilir (API limiti dolduğunda veya ağ bağlantısı olmadığında boş görünür).
          </p>
        )
      }
    </div>
  </section>
</Base>
