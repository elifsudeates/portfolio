---
import Base from "../../layouts/Base.astro";
import { getRepos } from "../../lib/github";
import { marked } from "marked";

// Her repo için /projects/<repo-adı> sayfası üret
export async function getStaticPaths() {
  const repos = await getRepos();
  return repos.map((repo) => ({
    params: { name: repo.name },
    props: { repo },
  }));
}

const { repo } = Astro.props;

// Repo README'sini çek ve Markdown'ı HTML'e çevir
let readmeHtml = "";
try {
  const token = import.meta.env.GITHUB_TOKEN ?? process.env.GITHUB_TOKEN;
  const headers: Record<string, string> = {
    Accept: "application/vnd.github.raw+json",
  };
  if (token) headers.Authorization = `Bearer ${token}`;

  const res = await fetch(
    `https://api.github.com/repos/cagatayuresin/${repo.name}/readme`,
    { headers }
  );
  if (res.ok) {
    const md = await res.text();
    readmeHtml = await marked.parse(md);
  }
} catch {
  readmeHtml = "";
}

const fmt = (s: string) =>
  new Date(s).toLocaleDateString("en-US", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
---

<Base
  title={`${repo.name} — Project`}
  description={
    repo.description ??
    `GitHub project page for ${repo.name} by Çağatay Üresin.`
  }
  canonicalPath={`/projects/${repo.name}`}
>
  <article class="container prose">
    <a href="/projects" class="back-link">← All projects</a>
    <h1>{repo.name}</h1>
    {repo.description && <p class="card-desc">{repo.description}</p>}

    <div class="repo-stats" style="margin:14px 0 8px">
      {repo.language && <span>● {repo.language}</span>}
      <span>★ {repo.stargazers_count}</span>
      <span>⑂ {repo.forks_count}</span>
      <span>Last updated: {fmt(repo.pushed_at)}</span>
    </div>

    <div class="meta" style="margin-bottom:8px">
      <a href={repo.html_url} target="_blank">Open on GitHub →</a>
      {
        repo.homepage && (
          <a href={repo.homepage} target="_blank">
            Live demo →
          </a>
        )
      }
    </div>

    {
      readmeHtml ? (
        <div set:html={readmeHtml} />
      ) : (
        <p class="card-desc">No README found for this repo.</p>
      )
    }
  </article>
</Base>
