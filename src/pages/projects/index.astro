---
import Base from "../../layouts/Base.astro";
import RepoCard from "../../components/RepoCard.astro";
import { getRepos } from "../../lib/github";

const repos = await getRepos();
---

<Base
  title="Projeler — Elif Sude Ateş"
  description="Elif Sude Ateş'in GitHub repolarından otomatik olarak oluşturulan açık kaynaklı projeleri."
  canonicalPath="/projects"
>
  <section class="container container-wide" style="padding-top:48px">
    <h1 style="letter-spacing:-0.02em">Projeler</h1>
    <p class="card-desc" style="margin-bottom:28px">
      GitHub üzerindeki açık kaynak çalışmalarım — derleme sırasında otomatik olarak en yenisi en üstte olacak şekilde çekilir.
    </p>
    <div class="card-grid repo-grid">
      {repos.map((r) => <RepoCard repo={r} />)}
      {
        repos.length === 0 && (
          <p class="card-desc">
            Projeler şu anda çekilemedi. Yerel geliştirmede GitHub API limiti (saatte 60 istek) dolmuş olabilir. CI ortamında GITHUB_TOKEN kullanılarak bu sorun önlenir.
          </p>
        )
      }
    </div>
  </section>
</Base>
