---
import Base from "../../layouts/Base.astro";
import RepoCard from "../../components/RepoCard.astro";
import { getRepos } from "../../lib/github";

const repos = await getRepos();
---

<Base title="Projects — Çağatay Üresin">
  <section class="container" style="padding-top:48px">
    <h1 style="letter-spacing:-0.02em">Projects</h1>
    <p class="card-desc" style="margin-bottom:28px">
      My open-source work on GitHub — fetched automatically at build time.
    </p>
    <div class="card-grid">
      {repos.map((r) => <RepoCard repo={r} />)}
      {
        repos.length === 0 && (
          <p class="card-desc">
            Repos couldn't be fetched right now. In local dev this can happen
            if the GitHub API rate limit (60/hour) is hit; setting
            GITHUB_TOKEN in CI avoids the issue.
          </p>
        )
      }
    </div>
  </section>
</Base>
