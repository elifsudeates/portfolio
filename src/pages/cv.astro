---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import type { IconName } from "../components/Icon.astro";

const initials = (name: string) =>
  name
    .replace(/[()]/g, "")
    .split(/[\s/.-]+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0])
    .join("")
    .toUpperCase();

type Skill = {
  name: string;
  icon: IconName;
  mark?: string;
};

const skill = (name: string, icon: IconName, mark?: string): Skill => ({
  name,
  icon,
  mark: mark ?? initials(name),
});

const skillCategories = [];
const education = [];
const experience = [];
---

<Base
  title="CV — Elif Sude Ateş"
  description="Elif Sude Ateş'in eğitimi, profesyonel deneyimi ve yetenekleri."
  canonicalPath="/cv"
>
  <section class="container" style="padding-top:48px; padding-bottom:80px">
    <h1 style="letter-spacing:-0.02em">CV</h1>

    <div class="cv-section">
      <h2 class="cv-section-title">
        <Icon name="briefcase" />
        Deneyim
      </h2>
      {
        experience.map((e) => (
          <div class="cv-entry">
            <span class="cv-entry-icon">
              <Icon name="briefcase" />
            </span>
            <div class="cv-entry-content">
              <div class="cv-entry-head">
                <span class="cv-org">{e.org}</span>
                <span class="cv-period">{e.period}</span>
              </div>
              <p class="cv-role">{e.role}</p>
              {e.note && <p class="card-desc">{e.note}</p>}
            </div>
          </div>
        ))
      }
    </div>

    <div class="cv-section">
      <h2 class="cv-section-title">
        <Icon name="school" />
        Eğitim
      </h2>
      {
        education.map((e) => (
          <div class="cv-entry">
            <span class="cv-entry-icon">
              <Icon name="school" />
            </span>
            <div class="cv-entry-content">
              <div class="cv-entry-head">
                <span class="cv-org">{e.degree}</span>
                <span class="cv-period">{e.period}</span>
              </div>
              <p class="cv-role">{e.org}</p>
              {e.note && <p class="card-desc">{e.note}</p>}
            </div>
          </div>
        ))
      }
    </div>

    <div class="cv-section">
      <h2 class="cv-section-title">
        <Icon name="sparkles" />
        Yetenekler
      </h2>
      {
        skillCategories.map((cat) => (
          <div class="skill-category">
            <h3>{cat.title}</h3>
            <div class="skill-grid">
              {cat.skills.map((s) => (
                <div class="skill-item">
                  <span class="skill-logo">
                    <span class="skill-mark" aria-hidden="true">{s.mark}</span>
                    <Icon name={s.icon} size={30} />
                  </span>
                  <span class="skill-name">{s.name}</span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>
</Base>
