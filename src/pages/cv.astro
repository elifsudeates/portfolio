---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import type { IconName } from "../components/Icon.astro";

const initials = (name: string) =>
  name
    .replace(/[()]/g, "")
    .split(/[\s/.-]+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0])
    .join("")
    .toUpperCase();

type Skill = {
  name: string;
  icon: IconName;
  mark?: string;
};

const skill = (name: string, icon: IconName, mark?: string): Skill => ({
  name,
  icon,
  mark: mark ?? initials(name),
});

const skillCategories = [
