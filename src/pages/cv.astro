---

<Base title="CV — Çağatay Üresin" description="Education, experience, and skills.">
  <section class="container" style="padding-top:48px; padding-bottom:80px">
    <h1 style="letter-spacing:-0.02em">CV</h1>

    <div class="cv-section">
      <h2 class="cv-section-title">Experience</h2>
      {
        experience.map((e) => (
          <div class="cv-entry">
            <div class="cv-entry-head">
              <span class="cv-org">{e.org}</span>
              <span class="cv-period">{e.period}</span>
            </div>
            <p class="cv-role">{e.role}</p>
            {e.note && <p class="card-desc">{e.note}</p>}
          </div>
        ))
      }
    </div>

    <div class="cv-section">
      <h2 class="cv-section-title">Education</h2>
      {
        education.map((e) => (
          <div class="cv-entry">
            <div class="cv-entry-head">
              <span class="cv-org">{e.degree}</span>
              <span class="cv-period">{e.period}</span>
            </div>
            <p class="cv-role">{e.org}</p>
            {e.note && <p class="card-desc">{e.note}</p>}
          </div>
        ))
      }
    </div>

    <div class="cv-section">
      <h2 class="cv-section-title">Skills</h2>
      {
        skillCategories.map((cat) => (
          <div class="skill-category">
            <h3>{cat.title}</h3>
            <div class="skill-grid">
              {cat.skills.map((s) => (
                <div class="skill-item">
                  <span class:list={["skill-logo", s.icon && "has-image"]}>
                    <span class="skill-mark" aria-hidden="true">{s.mark}</span>
                    {s.icon && (
                      <img
                        src={s.icon}
                        alt=""
                        loading="lazy"
                        decoding="async"
                        onerror="this.parentElement.classList.remove('has-image');this.hidden=true"
                      />
                    )}
                  </span>
                  <span class="skill-name">{s.name}</span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>
</Base>
