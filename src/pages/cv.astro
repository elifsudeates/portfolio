---
import Base from "../layouts/Base.astro";

const skillIcon = (slug: string) =>
  `https://skillicons.dev/icons?i=${slug}&theme=light`;
const simpleIcon = (slug: string) => `https://cdn.simpleicons.org/${slug}/088395`;
const initials = (name: string) =>
  name
    .replace(/[()]/g, "")
    .split(/[\s/.-]+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0])
    .join("")
    .toUpperCase();

type Skill = {
  name: string;
  icon?: string;
  mark?: string;
};

const skill = (name: string, icon?: string, mark?: string): Skill => ({
  name,
  icon,
  mark: mark ?? initials(name),
});

const skillCategories = [
  {
    title: "DevOps & Platform Engineering",
    skills: [
      skill("Kubernetes", skillIcon("kubernetes")),
      skill("Docker", skillIcon("docker")),
      skill("Linux", skillIcon("linux")),
      skill("Nginx", skillIcon("nginx")),
      skill("Helm", simpleIcon("helm")),
      skill("Argo CD", simpleIcon("argo")),
      skill("Cluster Bootstrap"),
      skill("Resource Limits"),
      skill("Certificate Automation"),
    ],
  },
  {
    title: "Infrastructure & Operations",
    skills: [
      skill("On-Premise Infrastructure"),
      skill("Master/Worker/Data Nodes", undefined, "MW"),
      skill("Preflight Checks"),
      skill("Systemd", skillIcon("systemd")),
      skill("Network Administration"),
      skill("DigitalOcean", simpleIcon("digitalocean")),
    ],
  },
  {
    title: "CI/CD & Automation",
    skills: [
      skill("GitLab", skillIcon("gitlab")),
      skill("Jenkins", skillIcon("jenkins")),
      skill("Bash", skillIcon("bash")),
      skill("Python", skillIcon("python")),
      skill("Ansible", skillIcon("ansible")),
