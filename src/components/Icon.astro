---
import article from "@tabler/icons/filled/article.svg?raw";
import automation from "@tabler/icons/outline/automation.svg?raw";
import api from "@tabler/icons/outline/api.svg?raw";
import arrowMerge from "@tabler/icons/outline/arrow-merge.svg?raw";
import bolt from "@tabler/icons/filled/bolt.svg?raw";
import box from "@tabler/icons/outline/box.svg?raw";
import brain from "@tabler/icons/outline/brain.svg?raw";
import brandAnsible from "@tabler/icons/outline/brand-ansible.svg?raw";
import brandDjango from "@tabler/icons/outline/brand-django.svg?raw";
import brandDocker from "@tabler/icons/outline/brand-docker.svg?raw";
