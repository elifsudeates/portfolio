---
import "../styles/global.css";
import "@fontsource-variable/inter/wght.css";
import Icon from "../components/Icon.astro";

interface Props {
  title: string;
  description?: string;
  image?: {
    src: string;
    alt: string;
    width?: number;
    height?: number;
  };
  canonicalPath?: string;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  lang?: string;
  locale?: string;
}

const {
  title,
  description = "Backend and DevOps portfolio by Çağatay Üresin, covering Kubernetes, GitOps, AI integrations, and open-source engineering projects.",
  image = {
    src: "/logo.png",
    alt: "Çağatay Üresin portfolio logo",
    width: 300,
    height: 300,
  },
  canonicalPath = Astro.url.pathname,
  type = "website",
  publishedTime,
  modifiedTime,
  tags = [],
  lang = "en",
  locale = "en_US",
} = Astro.props;

const site = Astro.site ?? new URL("https://cagatayuresin.com");
const normalizedCanonicalPath =
  canonicalPath === "/" || canonicalPath.endsWith("/")
    ? canonicalPath
    : `${canonicalPath}/`;
const canonicalUrl = new URL(normalizedCanonicalPath, site);
const imageUrl = new URL(image.src, site);
const pageTitle = title.includes("Çağatay Üresin")
  ? title
  : `${title} — Çağatay Üresin`;
const author = {
  "@type": "Person",
  name: "Çağatay Üresin",
  url: new URL("/", site).toString(),
  sameAs: [
    "https://github.com/cagatayuresin",
    "https://www.linkedin.com/in/cagatayuresin",
  ],
};
const jsonLd =
  type === "article"
    ? {
        "@context": "https://schema.org",
        "@type": "Article",
        headline: title,
        description,
        image: [imageUrl.toString()],
        datePublished: publishedTime,
        dateModified: modifiedTime ?? publishedTime,
        author,
        publisher: author,
        keywords: tags.join(", "),
        mainEntityOfPage: canonicalUrl.toString(),
      }
    : {
        "@context": "https://schema.org",
        "@type": "WebPage",
        name: title,
        description,
        url: canonicalUrl.toString(),
        image: imageUrl.toString(),
        author,
      };
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <meta name="description" content={description} />
    <meta name="author" content="Çağatay Üresin" />
    {tags.length > 0 && <meta name="keywords" content={tags.join(", ")} />}
    <meta name="robots" content="index, follow" />
    <meta property="og:site_name" content="Çağatay Üresin" />
    <meta property="og:locale" content={locale} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={imageUrl.toString()} />
    <meta property="og:image:secure_url" content={imageUrl.toString()} />
    <meta property="og:image:alt" content={image.alt} />
    {image.width && <meta property="og:image:width" content={String(image.width)} />}
    {image.height && <meta property="og:image:height" content={String(image.height)} />}
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl.toString()} />
    <meta name="twitter:image:alt" content={image.alt} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <title>{pageTitle}</title>
    <!-- Runs before paint to avoid a theme flash -->
    <script is:inline>
      const theme = localStorage.getItem("theme");
      if (
        theme === "dark" ||
        (!theme && window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container nav">
        <a href="/" class="nav-brand">
          <img src="/logo.png" alt="Çağatay Üresin" class="nav-logo" />
          cagatayuresin
        </a>
        <nav class="nav-links">
          <a href="/blog"><Icon name="article" />Blog</a>
          <a href="/projects"><Icon name="folders" />Projects</a>
          <a href="/cv"><Icon name="file-cv" />CV</a>
          <a href="https://github.com/cagatayuresin" target="_blank" rel="noreferrer">
            <Icon name="brand-github" />GitHub
          </a>
          <button
            class="theme-toggle"
            id="theme-toggle"
            aria-label="Toggle theme">
            <Icon name="moon" class="theme-icon theme-icon-moon" />
            <Icon name="sun" class="theme-icon theme-icon-sun" />
          </button
          >
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <a href="/" class="footer-logo" aria-label="Çağatay Üresin home">
          <img src="/logo.png" alt="" />
        </a>
        <div class="footer-socials" aria-label="Social links">
          <a href="https://www.linkedin.com/in/cagatayuresin" target="_blank" rel="noreferrer" aria-label="LinkedIn">
            <Icon name="brand-linkedin" />
          </a>
          <a href="mailto:cagatayuresin@gmail.com" aria-label="Gmail">
            <Icon name="brand-gmail" />
          </a>
          <a href="https://github.com/cagatayuresin" target="_blank" rel="noreferrer" aria-label="GitHub">
            <Icon name="brand-github" />
          </a>
        </div>
        <p>© {new Date().getFullYear()} Çağatay Üresin · Built with Astro</p>
      </div>
    </footer>

    <script is:inline>
      const btn = document.getElementById("theme-toggle");
      const root = document.documentElement;
      btn.addEventListener("click", () => {
        root.classList.toggle("dark");
        localStorage.setItem(
          "theme",
          root.classList.contains("dark") ? "dark" : "light"
        );
      });
    </script>
  </body>
</html>
